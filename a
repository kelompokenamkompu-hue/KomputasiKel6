/* ===== WORLD INIT ===== */
function initWorld(){
  const sf=SF();
  corals=[];weeds=[];clouds=[];plank=[];
  for(let i=0;i<28;i++){
    const t=Math.floor(Math.random()*4);
    const hs=[[300,60],[180,80],[30,40],[200,60]][t];
    const c=`hsl(${hs[0]+Math.random()*hs[1]},${55+Math.random()*35}%,${40+Math.random()*22}%)`;
    const sz=14+Math.random()*36;
    const det=[];
    if(t===0) for(let b=0;b<5;b++) det.push({a:(b/5)*Math.PI-Math.PI*.5+(Math.random()-.5)*.5,len:sz*(.5+Math.random()*.7)});
    else if(t===1) for(let b=0;b<8;b++) det.push({a:(b/8)*Math.PI*2,r:sz*.3});
    else if(t===3) for(let b=-2;b<=2;b++) det.push({dx:b*9,h:sz*(.7+Math.random()*.4)});
    corals.push({x:Math.random()*canvas.width,y:canvas.height-20-Math.random()*55,t,sz,c,det});
  }
  for(let i=0;i<28;i++) weeds.push({x:Math.random()*canvas.width,y:canvas.height-5,h:45+Math.random()*100,segs:Math.floor(Math.random()*3)+5,ph:Math.random()*Math.PI*2,c:`hsl(${100+Math.random()*60},${50+Math.random()*30}%,${22+Math.random()*20}%)`});
  for(let i=0;i<8;i++) clouds.push({x:Math.random()*canvas.width,y:Math.random()*sf*.55,r:40+Math.random()*65,sp:.1+Math.random()*.22});
  for(let i=0;i<130;i++) plank.push({x:Math.random()*canvas.width,y:sf+Math.random()*(canvas.height-sf),r:Math.random()*1.5+.4,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3});
  P.x=canvas.width/2; P.hy=sf+28;
}
initWorld();

/* ===== SPAWN ===== */
function spawn(){
  const sf=SF(),r=Math.random();
  if(r<.55){
    const t=FISH[Math.floor(Math.random()*FISH.length)],left=Math.random()>.5;
    const spd=t.sp*(.6+Math.random()*.8),mn=sf+55,mx=canvas.height-120;
    objs.push({k:'fish',t,sz:t.sz,x:left?-t.sz*3:canvas.width+t.sz*3,y:mn+Math.random()*(mx-mn),vx:left?spd:-spd,vy:0,ph:Math.random()*Math.PI*2,sc:false,sct:0});
  } else if(r<.88){
    const t=TRASH[Math.floor(Math.random()*TRASH.length)];
    objs.push({k:'trash',t,sz:t.sz,x:t.sz+Math.random()*(canvas.width-t.sz*2),y:sf+5,vx:(Math.random()-.5)*.3,vy:.6+Math.random()*1.1,rot:Math.random()*Math.PI*2,rspd:(Math.random()-.5)*.025,rest:false});
  } else {
    objs.push({k:'bomb',sz:27,x:45+Math.random()*(canvas.width-90),y:sf+5,vx:(Math.random()-.5)*.4,vy:.4+Math.random()*.75,rot:0,rspd:.025,gph:Math.random()*Math.PI*2,rest:false});
  }
}

/* ===== PARTICLES ===== */
function fx(x,y,col,n){
  for(let i=0;i<n;i++){const a=Math.random()*Math.PI*2,sp=55+Math.random()*120;
    parts.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-65,c:col,r:2+Math.random()*4,l:.4+Math.random()*.5,ml:.9,a:1});}
}
function ftext(x,y,txt,col,life=1.6){ftxts.push({x,y,txt,col,l:life,a:1});}

/* ===== UPDATE ===== */
function update(dt){
  if(!G.active) return;
  wt+=dt*.9;
  const sf=SF();

  // Hook
  if(P.drop){P.hy+=360*dt; if(P.hy>canvas.height-50) P.drop=false;}
  else P.hy=Math.max(sf+28,P.hy-470*dt);

  // Combo decay
  if(G.comboT>0){G.comboT-=dt; if(G.comboT<=0)G.combo=0;}

  // Bubbles
  if(Math.random()<dt*1.8) bubs.push({x:Math.random()*canvas.width,y:canvas.height,r:1+Math.random()*2.5,sp:25+Math.random()*45,w:Math.random()*Math.PI*2});
  bubs.forEach(b=>{b.y-=b.sp*dt;b.w+=dt*2.5;b.x+=Math.sin(b.w)*.4;});
  bubs=bubs.filter(b=>b.y>sf-10);

  // Plankton
  plank.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0)p.x=canvas.width;if(p.x>canvas.width)p.x=0;if(p.y<sf)p.y=canvas.height;if(p.y>canvas.height)p.y=sf;});

  // Particles
  parts.forEach(p=>{p.x+=p.vx*dt;p.y+=p.vy*dt;p.vy+=90*dt;p.l-=dt;p.a=p.l/p.ml;});
  parts=parts.filter(p=>p.l>0);

  // Float texts
  ftxts.forEach(t=>{t.y-=52*dt;t.l-=dt;t.a=Math.min(1,t.l/.8);});
  ftxts=ftxts.filter(t=>t.l>0);

  // Clouds
  clouds.forEach(c=>{c.x+=c.sp;if(c.x>canvas.width+200)c.x=-200;});

  // Seaweed
  weeds.forEach(w=>w.ph+=dt*1.5);

  // Objects
  objs.forEach(o=>{
    if(o.k==='fish'){
      o.ph+=dt*3.5;
      if(P.drop){const dx=P.x-o.x,dy=P.hy-o.y,d=Math.sqrt(dx*dx+dy*dy);
        if(d<135){o.sc=true;o.sct=2.5;o.vx+=(-dx/d)*7*dt;o.vy+=(-dy/d)*4*dt;}
      }
      o.vx=Math.max(-4.5,Math.min(4.5,o.vx));o.vy=Math.max(-2.5,Math.min(2.5,o.vy));
      if(o.sct>0){o.sct-=dt;if(o.sct<=0){o.sc=false;const s=o.t.sp;o.vx=o.vx>0?s:-s;o.vy=0;}}
      o.x+=o.vx;o.y+=o.vy+Math.sin(o.ph*.5)*.35;
      const mn=sf+40,mx=canvas.height-105;
      if(o.y<mn){o.y=mn;o.vy*=-.5;}if(o.y>mx){o.y=mx;o.vy*=-.5;}
    } else {
      o.rot+=o.rspd;o.x+=o.vx;
      if(o.k==='bomb')o.gph+=dt*3.2;
      if(!o.rest){o.y+=o.vy;if(o.y>canvas.height-92){o.y=canvas.height-92;o.rest=true;o.vy=0;}}
    }
  });

  // Collision
  const hx=P.x,hy=P.hy,hr=14;
  objs=objs.filter(o=>{
    const d=Math.sqrt((hx-o.x)**2+(hy-o.y)**2);
    const r=o.sz*(o.k==='fish'?.6:.55);
    if(d<r+hr){
      if(o.k==='trash'){
        G.combo++;G.comboT=3.2;
        const m=Math.min(G.combo,6),pts=o.t.p*m;
        G.score+=pts;G.poll=Math.max(0,G.poll+o.t.rd);
        G.eco=Math.min(100,G.eco+6);G.cleaned++;
        fx(hx,hy,'#4CAF50',10);
        ftext(hx,hy,`+${pts}${m>1?` ×${m}!`:''}`,m>1?'#FFD700':'#4CAF50',1.8);
      } else if(o.k==='fish'){
        G.fish=Math.max(0,G.fish-1);G.score=Math.max(0,G.score+o.t.p);
        G.combo=0;G.eco=Math.max(0,G.eco-15);
        fx(hx,hy,'#FF7043',6);
        ftext(hx,hy,`${o.t.p} ${o.t.n}!`,'#FF7043',2);
        ftext(hx,hy-32,`"${o.t.f}"`,'#FFFDE7',3);
        addInventory(o.t);
      } else {
        G.score=Math.max(0,G.score-50);G.poll=Math.min(100,G.poll+20);G.combo=0;
        fx(hx,hy,'#F44336',20);ftext(hx,hy,'💥 -50 BOOM!','#F44336',2.5);
      }
      P.drop=false;updateHUD();return false;
    }
    if(o.k==='fish'&&(o.x>canvas.width+320||o.x<-320))return false;
    return true;
  });
  updateHUD();
}

/* ===== DRAW SKY ===== */
function drawSky(sf){
  const g=ctx.createLinearGradient(0,0,0,sf);
  g.addColorStop(0,'#0d3b6e');g.addColorStop(.5,'#1a6db5');g.addColorStop(1,'#5ab4e0');
  ctx.fillStyle=g;ctx.fillRect(0,0,canvas.width,sf);
  // Sun
  const sx=canvas.width*.78,sy=sf*.25;
  const sg=ctx.createRadialGradient(sx,sy,0,sx,sy,95);
  sg.addColorStop(0,'rgba(255,255,220,1)');sg.addColorStop(.3,'rgba(255,220,80,.6)');sg.addColorStop(1,'rgba(255,200,0,0)');
  ctx.fillStyle=sg;ctx.fillRect(sx-95,sy-95,190,190);
  ctx.beginPath();ctx.arc(sx,sy,28,0,Math.PI*2);ctx.fillStyle='#FFFDE7';ctx.fill();
  // Sun rays
  ctx.save();ctx.globalAlpha=.12;ctx.strokeStyle='#FFD700';ctx.lineWidth=2;
  for(let i=0;i<12;i++){const a=(i/12)*Math.PI*2;ctx.beginPath();ctx.moveTo(sx+Math.cos(a)*32,sy+Math.sin(a)*32);ctx.lineTo(sx+Math.cos(a)*65,sy+Math.sin(a)*65);ctx.stroke();}
  ctx.restore();
  // Clouds
  clouds.forEach(c=>{
    ctx.save();ctx.fillStyle='rgba(255,255,255,.88)';
    ctx.beginPath();ctx.arc(c.x,c.y,c.r*.5,0,Math.PI*2);ctx.arc(c.x+c.r*.4,c.y-c.r*.1,c.r*.38,0,Math.PI*2);
    ctx.arc(c.x-c.r*.35,c.y+c.r*.05,c.r*.32,0,Math.PI*2);ctx.arc(c.x+c.r*.72,c.y+c.r*.05,c.r*.28,0,Math.PI*2);
    ctx.fill();ctx.restore();
  });
}

/* ===== DRAW OCEAN ===== */
function drawOcean(sf){
  const pf=G.poll/100;
  const wg=ctx.createLinearGradient(0,sf,0,canvas.height);
  wg.addColorStop(0,`rgb(${~~lerp(12,75,pf)},${~~lerp(105,70,pf)},${~~lerp(195,55,pf)})`);
  wg.addColorStop(.3,`rgb(${~~lerp(4,48,pf)},${~~lerp(55,38,pf)},${~~lerp(115,22,pf)})`);
  wg.addColorStop(.7,'rgb(1,16,32)');wg.addColorStop(1,'rgb(0,5,10)');
  ctx.beginPath();ctx.moveTo(0,sf);
  for(let x=0;x<=canvas.width;x+=8){ctx.lineTo(x,sf+Math.sin(x*.018+wt)*7+Math.sin(x*.044+wt*1.4)*3);}
  ctx.lineTo(canvas.width,canvas.height);ctx.lineTo(0,canvas.height);ctx.fillStyle=wg;ctx.fill();
  // Shimmer
  ctx.beginPath();ctx.moveTo(0,sf);
  for(let x=0;x<=canvas.width;x+=8)ctx.lineTo(x,sf+Math.sin(x*.018+wt)*7+Math.sin(x*.044+wt*1.4)*3);
  ctx.strokeStyle='rgba(255,255,255,.32)';ctx.lineWidth=2.5;ctx.stroke();
}

/* ===== GOD RAYS ===== */
function drawRays(sf){
  ctx.save();ctx.globalCompositeOperation='screen';
  for(let i=0;i<8;i++){
    const rx=canvas.width*.08+canvas.width*.11*i+Math.sin(wt*.22+i*1.3)*75;
    const w1=35+Math.sin(wt*.38+i)*14,w2=190+Math.sin(wt*.22+i)*85;
    const rg=ctx.createLinearGradient(0,sf,0,canvas.height);
    rg.addColorStop(0,`rgba(130,215,255,${.035+Math.sin(wt*.28+i)*.012})`);rg.addColorStop(1,'rgba(30,80,180,0)');
    ctx.beginPath();ctx.moveTo(rx,sf);ctx.lineTo(rx+w1,sf);ctx.lineTo(rx+w2,canvas.height);ctx.lineTo(rx-w2*.28,canvas.height);
    ctx.fillStyle=rg;ctx.fill();
  }
  ctx.restore();
}

/* ===== SEAFLOOR ===== */
function drawFloor(){
  const fy=canvas.height-72;
  const fg=ctx.createLinearGradient(0,fy,0,canvas.height);
  fg.addColorStop(0,'#1a3a10');fg.addColorStop(.5,'#0d1e08');fg.addColorStop(1,'#04090200');
  ctx.fillStyle=fg;ctx.beginPath();ctx.moveTo(0,canvas.height);ctx.lineTo(0,fy+18);
  for(let x=0;x<=canvas.width;x+=24)ctx.lineTo(x,fy+Math.sin(x*.038)*19+Math.sin(x*.017)*26);
  ctx.lineTo(canvas.width,canvas.height);ctx.fill();
  // Sand
  ctx.fillStyle='rgba(205,190,140,.22)';
  for(let i=0;i<12;i++){ctx.beginPath();ctx.ellipse((canvas.width/12)*i+20,fy+14,38+i*2,11,0,0,Math.PI*2);ctx.fill();}
}

/* ===== SEAWEED ===== */
function drawWeeds(){
  weeds.forEach(w=>{
    ctx.strokeStyle=w.c;ctx.lineWidth=3;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(w.x,w.y);
    for(let i=1;i<=w.segs;i++){const t=i/w.segs,wx=Math.sin(w.ph+t*Math.PI*2.5)*13;ctx.quadraticCurveTo(w.x+wx+10,w.y-t*w.h+w.h/(w.segs*2),w.x+wx,w.y-t*w.h);}
    ctx.stroke();
  });
}

/* ===== CORALS ===== */
function drawCorals(){
  corals.forEach(c=>{
    ctx.fillStyle=c.c;ctx.strokeStyle=c.c;
    switch(c.t){
      case 0:ctx.lineWidth=3;ctx.lineCap='round';c.det.forEach(d=>{ctx.beginPath();ctx.moveTo(c.x,c.y);ctx.lineTo(c.x+Math.cos(d.a)*d.len,c.y+Math.sin(d.a)*d.len);ctx.stroke();});break;
      case 1:ctx.beginPath();ctx.arc(c.x,c.y,c.sz*.62,0,Math.PI*2);ctx.fill();ctx.fillStyle='rgba(255,255,255,.18)';c.det.forEach(d=>{ctx.beginPath();ctx.arc(c.x+Math.cos(d.a)*d.r,c.y+Math.sin(d.a)*d.r,3.5,0,Math.PI*2);ctx.fill();});break;
      case 2:ctx.lineWidth=1.5;for(let i=-5;i<=5;i++){const a=i*.18-Math.PI*.5;ctx.beginPath();ctx.moveTo(c.x,c.y);ctx.lineTo(c.x+Math.cos(a)*c.sz,c.y+Math.sin(a)*c.sz);ctx.stroke();}break;
      case 3:c.det.forEach(d=>{ctx.fillStyle=c.c;ctx.fillRect(c.x+d.dx-4,c.y-d.h,8,d.h);ctx.beginPath();ctx.arc(c.x+d.dx,c.y-d.h,6.5,0,Math.PI*2);ctx.fillStyle='rgba(255,80,150,.85)';ctx.fill();});break;
    }
  });
}

