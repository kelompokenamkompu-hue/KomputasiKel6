/* ===== BOAT ===== */
function drawBoat(){
  const sf=SF(),x=P.x,wy=Math.sin(x*.012+wt)*5,y=sf-8+wy,W=155,H=68;
  ctx.save();ctx.translate(x,y);ctx.scale(P.dir,1);
  // Wake
  ctx.save();ctx.scale(1/P.dir,1);
  const wkg=ctx.createRadialGradient(0,H*.35,0,0,H*.35,90);
  wkg.addColorStop(0,'rgba(255,255,255,.22)');wkg.addColorStop(1,'rgba(255,255,255,0)');
  ctx.fillStyle=wkg;ctx.fillRect(-85,-2,170,H*.5);ctx.restore();
  // Hull
  ctx.beginPath();ctx.moveTo(-W/2+4,H*.48);ctx.lineTo(-W/2,0);ctx.lineTo(-W/2,-H*.28);
  ctx.lineTo(W/2-6,-H*.28);ctx.lineTo(W/2+28,H*.08);ctx.lineTo(W/2+12,H*.48);ctx.closePath();
  const hg=ctx.createLinearGradient(0,-H*.28,0,H*.48);
  hg.addColorStop(0,'#c62828');hg.addColorStop(.45,'#922b21');hg.addColorStop(1,'#5c1616');
  ctx.fillStyle=hg;ctx.fill();ctx.strokeStyle='rgba(0,0,0,.4)';ctx.lineWidth=1.5;ctx.stroke();
  // Waterline
  ctx.beginPath();ctx.moveTo(-W/2,H*.1);ctx.lineTo(W/2+18,H*.1);ctx.strokeStyle='rgba(240,190,130,.6)';ctx.lineWidth=2.5;ctx.stroke();
  // Deck
  ctx.fillStyle='#BDC3C7';ctx.beginPath();ctx.roundRect(-W/2+5,-H*.28,W-14,H*.2,3);ctx.fill();
  // Cabin
  ctx.fillStyle='#95A5A6';ctx.fillRect(-8,-H*.88,58,H*.62);
  ctx.fillStyle='#7F8C8D';ctx.fillRect(-8,-H*.9,58,H*.06);
  ctx.fillStyle='rgba(100,210,255,.72)';ctx.fillRect(4,-H*.75,15,14);ctx.fillRect(28,-H*.75,14,14);
  // Mast
  ctx.strokeStyle='#4E342E';ctx.lineWidth=5;ctx.lineCap='round';
  ctx.beginPath();ctx.moveTo(24,-H*.28);ctx.lineTo(24,-H*1.7);ctx.stroke();
  // Crane
  ctx.strokeStyle='#78909C';ctx.lineWidth=3;
  ctx.beginPath();ctx.moveTo(-6,-H*.48);ctx.lineTo(4,-H*.82);ctx.lineTo(58,-H*.68);ctx.stroke();
  // Pulley dot
  ctx.beginPath();ctx.arc(58,-H*.68,4,0,Math.PI*2);ctx.fillStyle='#546E7A';ctx.fill();
  // Flag
  const fw=Math.sin(wt*2)*9;
  ctx.fillStyle='#1565C0';ctx.beginPath();ctx.moveTo(24,-H*1.7);ctx.lineTo(54+fw,-H*1.58);ctx.lineTo(24,-H*1.46);ctx.fill();
  ctx.restore();
}

/* ===== HOOK ===== */
function drawHook(){
  const sf=SF(),x=P.x,mx=x+Math.sin(wt*.4)*6;
  ctx.beginPath();ctx.moveTo(x,sf+4);ctx.quadraticCurveTo(mx,(sf+P.hy)*.5,x,P.hy);
  ctx.strokeStyle='rgba(200,200,200,.75)';ctx.lineWidth=1.5;ctx.stroke();
  ctx.save();ctx.translate(x,P.hy);
  ctx.strokeStyle='#B0BEC5';ctx.lineWidth=3;ctx.lineCap='round';
  ctx.beginPath();ctx.moveTo(0,-18);ctx.lineTo(0,9);ctx.arc(9,9,9,Math.PI,Math.PI*.1,true);ctx.stroke();
  ctx.shadowColor='rgba(100,225,255,.8)';ctx.shadowBlur=14;
  ctx.beginPath();ctx.arc(0,4,5.5,0,Math.PI*2);ctx.fillStyle='rgba(100,225,255,.4)';ctx.fill();
  ctx.restore();
}

/* ===== FISH DRAWING ===== */
function drawFish(o){
  ctx.save();ctx.translate(o.x,o.y);
  const dir=o.vx>=0?1:-1;ctx.scale(dir,1);
  const s=o.sz,sp=o.ph,t=o.t;

  if(t.n==='Ubur-ubur'){
    const jg=ctx.createRadialGradient(0,0,0,0,0,s);
    jg.addColorStop(0,lighten(t.c,50));jg.addColorStop(1,t.c);
    ctx.fillStyle=jg;ctx.globalAlpha=.82;
    ctx.beginPath();ctx.arc(0,0,s,Math.PI,0);ctx.fill();ctx.globalAlpha=1;
    ctx.strokeStyle=t.c;ctx.lineWidth=1.5;
    for(let i=-3;i<=3;i++){ctx.beginPath();ctx.moveTo(i*s*.28,s*.1);ctx.quadraticCurveTo(i*s*.25+Math.sin(sp+i)*s*.4,s*.7,i*s*.2+Math.sin(sp*1.3+i)*s*.35,s*1.25);ctx.stroke();}
  } else if(t.n==='Pari Manta'){
    ctx.fillStyle=t.c;ctx.beginPath();
    ctx.moveTo(s*.55,0);ctx.bezierCurveTo(s*.35,-s*.65,-s*.35,-s*.65,-s*.55,0);
    ctx.bezierCurveTo(-s*.35,s*.42,s*.35,s*.42,s*.55,0);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,.14)';ctx.beginPath();ctx.ellipse(0,0,s*.2,s*.08,0,0,Math.PI*2);ctx.fill();
  } else if(t.n==='Hiu'){
    ctx.fillStyle=t.c;
    ctx.beginPath();ctx.moveTo(s*.8,0);ctx.bezierCurveTo(s*.4,-s*.3,-s*.6,-s*.35,-s*.8,0);
    ctx.bezierCurveTo(-s*.6,s*.25,s*.4,s*.25,s*.8,0);ctx.fill();
    // Dorsal fin
    ctx.beginPath();ctx.moveTo(s*.1,-s*.3);ctx.lineTo(s*.35,-s*.7);ctx.lineTo(s*.55,-s*.25);ctx.closePath();ctx.fill();
    ctx.fillStyle=t.s;ctx.beginPath();ctx.ellipse(s*.5,s*.1,s*.18,s*.08,0,0,Math.PI*2);ctx.fill();
  } else {
    // Generic fish
    const bg=ctx.createRadialGradient(-s*.1,0,0,0,0,s);
    bg.addColorStop(0,lighten(t.c,48));bg.addColorStop(1,t.c);
    ctx.fillStyle=bg;ctx.beginPath();ctx.ellipse(0,0,s,s*.52,0,0,Math.PI*2);ctx.fill();
    ctx.fillStyle=t.c;ctx.beginPath();ctx.moveTo(-s*.7,0);ctx.lineTo(-s*1.32,-s*.38+Math.sin(sp)*s*.2);ctx.lineTo(-s*1.32,s*.38+Math.sin(sp)*s*.2);ctx.closePath();ctx.fill();
    ctx.save();ctx.globalAlpha=.42;ctx.strokeStyle=t.s;ctx.lineWidth=1.5;
    ctx.beginPath();ctx.moveTo(-s*.18,-s*.46);ctx.lineTo(-s*.18,s*.46);ctx.stroke();ctx.restore();
    // Dorsal fin
    ctx.fillStyle=lighten(t.c,20);ctx.beginPath();ctx.moveTo(-s*.1,-s*.5);ctx.lineTo(s*.2,-s*.75);ctx.lineTo(s*.4,-s*.5);ctx.closePath();ctx.fill();
  }
  // Eye
  ctx.fillStyle='#111';ctx.beginPath();ctx.arc(s*.48,-s*.1,s*.13,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(s*.5,-s*.12,s*.055,0,Math.PI*2);ctx.fill();
  if(o.sc){ctx.save();ctx.scale(1/dir,1);ctx.font=`${s*.55}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('😨',0,-s*1.12);ctx.restore();}
  ctx.restore();
}

/* ===== TRASH DRAWING ===== */
function drawTrash(o){
  ctx.save();ctx.translate(o.x,o.y);ctx.rotate(o.rot);
  const s=o.sz,t=o.t;ctx.fillStyle=t.c;
  switch(t.sh){
    case 'bottle':
      ctx.save();ctx.globalAlpha=.86;ctx.beginPath();ctx.roundRect(-s*.3,-s,s*.6,s*1.4,4);ctx.fill();
      ctx.fillStyle='rgba(255,255,255,.3)';ctx.fillRect(-s*.13,-s*.82,s*.15,s*.52);
      ctx.fillStyle='#aaa';ctx.fillRect(-s*.22,-s*1.12,s*.44,s*.16);ctx.restore();break;
    case 'can':
      ctx.fillRect(-s*.42,-s*.6,s*.84,s*1.22);ctx.fillStyle='#888';
      ctx.fillRect(-s*.42,-s*.6,s*.84,s*.14);ctx.fillRect(-s*.42,s*.48,s*.84,s*.14);
      ctx.fillStyle='rgba(255,255,255,.14)';ctx.fillRect(-s*.14,-s*.54,s*.12,s*.82);break;
    case 'bag':
      ctx.save();ctx.globalAlpha=.76;ctx.beginPath();ctx.moveTo(0,-s*.82);
      ctx.bezierCurveTo(s*.66,-s*.5,s*.66,s*.5,0,s*.82);ctx.bezierCurveTo(-s*.66,s*.5,-s*.66,-s*.5,0,-s*.82);ctx.fill();ctx.restore();break;
    case 'wreck':
      ctx.fillRect(-s*.48,-s*.3,s*.96,s*.56);ctx.fillStyle='#5D4037';ctx.fillRect(-s*.18,-s*.66,s*.32,s*.38);
      ctx.strokeStyle='rgba(0,0,0,.4)';ctx.lineWidth=1.5;
      for(let i=-3;i<=3;i++){ctx.beginPath();ctx.moveTo(i*s*.13,-s*.3);ctx.lineTo(i*s*.13,s*.26);ctx.stroke();}break;
    case 'net':
      ctx.strokeStyle=t.c;ctx.lineWidth=1.5;ctx.globalAlpha=.8;
      for(let i=-4;i<=4;i++){ctx.beginPath();ctx.moveTo(i*s*.12,-s);ctx.lineTo(i*s*.12,s);ctx.stroke();}
      for(let i=-3;i<=3;i++){ctx.beginPath();ctx.moveTo(-s,i*s*.3);ctx.lineTo(s,i*s*.3);ctx.stroke();}break;
    case 'battery':
      ctx.fillStyle='#1a1a1a';ctx.fillRect(-s*.42,-s*.72,s*.84,s*1.44);
      ctx.fillStyle='#C62828';ctx.fillRect(-s*.24,-s*.58,s*.48,s*.47);
      ctx.fillStyle='#1B5E20';ctx.fillRect(-s*.24,s*.06,s*.48,s*.47);
      ctx.fillStyle='#777';ctx.fillRect(-s*.16,-s*.74,s*.32,s*.08);break;
    case 'foam':
      ctx.fillStyle='#EEEEEE';ctx.fillRect(-s*.52,-s*.36,s*1.04,s*.72);
      ctx.strokeStyle='#CCC';ctx.lineWidth=1;
      for(let i=-2;i<=2;i++){ctx.beginPath();ctx.moveTo(i*s*.22,-s*.3);ctx.lineTo(i*s*.22,s*.3);ctx.stroke();}break;
    case 'drum':
      ctx.beginPath();ctx.arc(0,0,s,0,Math.PI*2);ctx.fill();
      ctx.strokeStyle='#333';ctx.lineWidth=2.5;ctx.beginPath();ctx.moveTo(-s,0);ctx.lineTo(s,0);ctx.stroke();
      ctx.beginPath();ctx.arc(0,0,s,0,Math.PI*2);ctx.stroke();
      ctx.font=`${s*.9}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillStyle='rgba(255,220,0,.85)';ctx.fillText('⚠',0,2);break;
  }
  ctx.globalAlpha=1;ctx.restore();
}

/* ===== BOMB DRAWING ===== */
function drawBomb(o){
  ctx.save();ctx.translate(o.x,o.y);ctx.rotate(o.rot);
  const s=o.sz,gf=Math.sin(o.gph)*.5+.5;
  const gg=ctx.createRadialGradient(0,0,5,0,0,s*2.2);
  gg.addColorStop(0,`rgba(255,60,0,${.3+gf*.38})`);gg.addColorStop(1,'rgba(255,0,0,0)');
  ctx.fillStyle=gg;ctx.fillRect(-s*2.2,-s*2.2,s*4.4,s*4.4);
  ctx.fillStyle='#2C2C2C';ctx.beginPath();ctx.arc(0,0,s,0,Math.PI*2);ctx.fill();
  ctx.strokeStyle='#555';ctx.lineWidth=2.5;ctx.beginPath();ctx.arc(0,0,s,0,Math.PI*2);ctx.stroke();
  ctx.beginPath();ctx.moveTo(-s,0);ctx.lineTo(s,0);ctx.stroke();
  ctx.beginPath();ctx.moveTo(-s*.7,-s*.7);ctx.lineTo(s*.7,-s*.7);ctx.stroke();
  ctx.font=`${s*1.1}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillStyle=`rgba(255,60,0,${.6+gf*.4})`;ctx.fillText('☠',0,1);
  ctx.restore();
}

/* ===== POLLUTION OVERLAY ===== */
function drawPollOverlay(){
  if(G.poll<5)return;
  const a=(G.poll/100)*.48,sf=SF();
  const og=ctx.createLinearGradient(0,sf,0,canvas.height);
  og.addColorStop(0,`rgba(100,65,0,${a*.7})`);og.addColorStop(1,`rgba(38,18,0,${a})`);
  ctx.fillStyle=og;ctx.fillRect(0,sf,canvas.width,canvas.height);
}

/* ===== PARTICLES & TEXTS ===== */
function drawParts(){parts.forEach(p=>{ctx.save();ctx.globalAlpha=p.a;ctx.fillStyle=p.c;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();ctx.restore();});}
function drawFTexts(){ftxts.forEach(t=>{ctx.save();ctx.globalAlpha=t.a;ctx.fillStyle=t.col;ctx.font='bold 17px Nunito,Arial';ctx.textAlign='center';ctx.shadowColor='rgba(0,0,0,.9)';ctx.shadowBlur=5;ctx.fillText(t.txt,t.x,t.y);ctx.restore();});}

/* ===== MAIN RENDER ===== */
function render(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  const sf=SF();
  drawSky(sf);drawOcean(sf);drawRays(sf);drawPollOverlay();
  drawFloor();drawWeeds();drawCorals();drawPlank();drawBubs();
  objs.forEach(o=>{if(o.k==='fish')drawFish(o);else if(o.k==='trash')drawTrash(o);else drawBomb(o);});
  drawHook();drawBoat();drawParts();drawFTexts();
}

/* ===== HUD ===== */
function updateHUD(){
  document.getElementById('sv-score').textContent=G.score;
  document.getElementById('sv-fish').textContent=G.fish;
  document.getElementById('sv-poll').textContent=G.poll+'%';
  document.getElementById('eco-fill').style.width=G.eco+'%';
  const cb=document.getElementById('combo-box');
  if(G.combo>1){cb.textContent=`🔥 ×${G.combo} COMBO!`;cb.style.opacity='1';}
  else cb.style.opacity='0';
  const tel=document.getElementById('timer');
  if(G.time<=30)tel.classList.add('warn');else tel.classList.remove('warn');
}

/* ===== INVENTORY ===== */
function addInventory(fish){
  const panel=document.getElementById('inv-panel');
  const d=document.createElement('div');d.className='inv-item';
  d.innerHTML=`<div class="inv-name">🐟 ${fish.n}</div><div class="inv-fact">"${fish.f}"</div>`;
  panel.appendChild(d);
}
document.getElementById('inv-btn').onclick=()=>{
  const p=document.getElementById('inv-panel');p.style.display=p.style.display==='block'?'none':'block';
};

/* ===== TIMER ===== */
function startTimer(){
  clearInterval(timerIv);
  timerIv=setInterval(()=>{
    if(!G.active)return;
    G.time--;
    const m=Math.floor(G.time/60).toString().padStart(2,'0'),s=(G.time%60).toString().padStart(2,'0');
    document.getElementById('timer').textContent=`${m}:${s}`;
    if(G.time<=0)endGame();
  },1000);
}

/* ===== GAME FLOW ===== */
function startGame(){
  document.getElementById('menu').classList.add('off');
  document.getElementById('gameover').classList.add('off');
  initState();objs=[];parts=[];bubs=[];ftxts=[];
  document.getElementById('inv-panel').innerHTML='';
  initWorld();G.active=true;
  startTimer();
  clearInterval(spawnIv);spawnIv=setInterval(spawn,1550);
  document.getElementById('timer').textContent='02:00';
  updateHUD();
}

function endGame(){
  G.active=false;clearInterval(timerIv);clearInterval(spawnIv);
  let emoji='🌊';
  if(G.score>=800)emoji='🌟';
  else if(G.score>=500)emoji='⭐';
  else if(G.score>=300)emoji='✨';
  else if(G.score>=150)emoji='💫';
  document.getElementById('go-title').textContent=G.poll<20?'🌊 LAUTAN BERSIH!':'⏰ WAKTU HABIS!';
  document.getElementById('go-title').style.color=G.poll<20?'#4FC3F7':'#EF5350';
  document.getElementById('go-rating').textContent=emoji;
  document.getElementById('gf-score').textContent=G.score;
  document.getElementById('gf-fish').textContent=G.fish;
  document.getElementById('gf-poll').textContent=G.poll;
  document.getElementById('gf-trash').textContent=G.cleaned;
  document.getElementById('gameover').classList.remove('off');
}

function resetGame(){document.getElementById('gameover').classList.add('off');startGame();}

/* ===== INPUT ===== */
const keys={};
document.addEventListener('keydown',e=>{
  keys[e.key]=true;
  if(e.key===' '&&G.active&&!P.drop){P.drop=true;e.preventDefault();}
  if(e.key==='ArrowLeft'||e.key==='ArrowRight')e.preventDefault();
});
document.addEventListener('keyup',e=>keys[e.key]=false);

// Mobile
['ml','mr','mc'].forEach(id=>{
  const el=document.getElementById(id);
  if(!el)return;
  el.addEventListener('touchstart',e=>{
    if(id==='ml')keys['ArrowLeft']=true;
    else if(id==='mr')keys['ArrowRight']=true;
    else if(id==='mc'&&G.active&&!P.drop)P.drop=true;
    e.preventDefault();
  },{passive:false});
  el.addEventListener('touchend',()=>{if(id==='ml')keys['ArrowLeft']=false;if(id==='mr')keys['ArrowRight']=false;});
});

/* ===== HELPERS ===== */
function lerp(a,b,t){return a+(b-a)*t;}
function lighten(hex,amt){
  try{if(!hex.startsWith('#'))return hex;const n=parseInt(hex.slice(1),16);return `rgb(${Math.min(255,(n>>16)+amt)},${Math.min(255,((n>>8)&255)+amt)},${Math.min(255,(n&255)+amt)})`;}
  catch{return hex;}
}

/* ===== MENU BG ANIMATION ===== */
(function menuAnim(){
  const mc=document.getElementById('mc2');
  if(!mc)return;
  mc.width=window.innerWidth;mc.height=window.innerHeight;
  const c2=mc.getContext('2d');
  let t=0,fish=Array.from({length:8},()=>({x:Math.random()*mc.width,y:mc.height*.4+Math.random()*mc.height*.5,vx:(Math.random()>.5?1:-1)*(.5+Math.random()),ph:Math.random()*Math.PI*2,sz:15+Math.random()*30,c:`hsl(${Math.random()*360},70%,55%)`}));
  function step(){
    requestAnimationFrame(step);t+=.015;
    c2.clearRect(0,0,mc.width,mc.height);
    const g=c2.createLinearGradient(0,0,0,mc.height);
    g.addColorStop(0,'#041827');g.addColorStop(1,'#062038');
    c2.fillStyle=g;c2.fillRect(0,0,mc.width,mc.height);
    c2.fillStyle='rgba(150,220,255,.08)';
    for(let i=0;i<80;i++){{c2.beginPath();c2.arc(Math.sin(i*2.3+t)*mc.width*.5+mc.width*.5,Math.sin(i*1.7+t*.8)*mc.height*.4+mc.height*.5,1+Math.random(),0,Math.PI*2);c2.fill();}}
    fish.forEach(f=>{f.ph+=.04;f.x+=f.vx;if(f.x>mc.width+100)f.x=-100;if(f.x<-100)f.x=mc.width+100;
      c2.save();c2.translate(f.x,f.y+Math.sin(f.ph)*.5*10);c2.scale(f.vx>0?1:-1,1);
      c2.fillStyle=f.c;c2.beginPath();c2.ellipse(0,0,f.sz,f.sz*.5,0,0,Math.PI*2);c2.fill();
      c2.beginPath();c2.moveTo(-f.sz*.7,0);c2.lineTo(-f.sz*1.3,-f.sz*.35+Math.sin(f.ph)*f.sz*.18);c2.lineTo(-f.sz*1.3,f.sz*.35+Math.sin(f.ph)*f.sz*.18);c2.closePath();c2.fill();
      c2.restore();});
  }
  step();
})();

/* ===== GAME LOOP ===== */
function loop(now){
  const dt=Math.min((now-lastT)/1000,.05);lastT=now;
  if(G.active){
    if(keys['ArrowLeft']&&P.x>62){P.x-=P.spd*dt;P.dir=-1;}
    if(keys['ArrowRight']&&P.x<canvas.width-62){P.x+=P.spd*dt;P.dir=1;}
  }
  update(dt);render();requestAnimationFrame(loop);
}
requestAnimationFrame(t=>{lastT=t;requestAnimationFrame(loop);});

